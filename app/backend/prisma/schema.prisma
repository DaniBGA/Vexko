generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ----------------------
// Multi-business schema
// ----------------------

model Customer {
  id        String    @id @default(cuid())
  name      String    @unique
  plan      String    @default("BASE")
  email     String?   @unique
  phone     String?
  address   String?
  kiosks    Kiosk[]
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Kiosk {
  id          String        @id @default(cuid())
  name        String
  address     String?
  phone       String?
  active      Boolean       @default(false)
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User?         @relation("KioskAccount")
  clients     Client[]
  invoices    Invoice[]
  kioskProducts KioskProduct[]
  sales       Sale[]
  suppliers   Supplier[]
  cashFlows   CashFlow[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([customerId, name])
  @@index([customerId])
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  subcategories Subcategory[]
  products    Product[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([name])
}

model Subcategory {
  id         String     @id @default(cuid())
  name       String
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id])
  products   Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Product {
  id           String       @id @default(cuid())
  name         String
  description  String?
  barcode      String?      @unique
  sku          String?      @unique
  loadMode     String       @default("pack")
  basePrice    Float?
  baseCost     Float?
  packPrice    Float?
  packUnits    Int?
  packCount    Int?
  categoryId   String?
  subcategoryId String?
  category     Category?    @relation(fields: [categoryId], references: [id])
  subcategory  Subcategory? @relation(fields: [subcategoryId], references: [id])
  isCustom     Boolean      @default(false)
  customerId   String?
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // compatibility fields (legacy app expects stock/minStock on Product)
  stock        Int?         @default(0)
  minStock     Int?         @default(0)
  salePrice    Float?
  costPrice    Float?
  expiresAt    DateTime?
  supplierId   String?
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])
  active       Boolean      @default(true)

  kioskProducts KioskProduct[]
  saleItems     SaleItem[]
  supplierProducts SupplierProduct[]
  purchaseItems PurchaseItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([categoryId])
  @@index([customerId])
  @@index([isCustom])
  @@index([active, isCustom])
  @@index([name])
}

model KioskProduct {
  id         String   @id @default(cuid())
  kioskId    String
  productId  String
  stock      Int      @default(0)
  minStock   Int      @default(0)
  price      Float?
  kiosk      Kiosk    @relation(fields: [kioskId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([kioskId, productId])
  @@index([kioskId])
  @@index([productId])
}

model Sale {
  id            String     @id @default(cuid())
  date          DateTime   @default(now())
  total         Float
  paymentMethod String
  cashAmount    Float?
  transferAmount Float?
  cardAmount    Float?
  cashReceived  Float?
  changeGiven   Float?
  pointsEarned  Int      @default(0)
  kioskId       String
  kiosk         Kiosk      @relation(fields: [kioskId], references: [id])
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  clientId      String?
  client        Client?    @relation("ClientSales", fields: [clientId], references: [id])
  items         SaleItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([kioskId])
  @@index([userId])
  @@index([date])
  @@index([kioskId, createdAt])
  @@index([userId, createdAt])
  @@index([paymentMethod, createdAt])
}

model SaleItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Float
  subtotal   Float
  saleId     String
  productId  String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@index([saleId, productId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  email     String?
  address   String?
  kioskId   String?
  kiosk     Kiosk?   @relation(fields: [kioskId], references: [id])
  products  SupplierProduct[]
  purchases Purchase[]
  items     Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kioskId])
}

model SupplierProduct {
  id         String   @id @default(cuid())
  cost       Float?
  leadDays   Int?
  supplierId String
  productId  String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
}

model CashFlow {
  id        String   @id @default(cuid())
  type      String
  amount    Float
  description String?
  category  String?
  kioskId   String
  kiosk     Kiosk    @relation(fields: [kioskId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kioskId])
  @@index([type])
  @@index([category])
  @@index([createdAt])
  @@index([type, createdAt])
  @@index([kioskId, createdAt])
}

// ----------------------
// App-specific models (auth, clients, invoices, loyalty)
// ----------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  active       Boolean  @default(true)
  kioskId      String?  @unique
  kiosk        Kiosk?   @relation("KioskAccount", fields: [kioskId], references: [id], onDelete: SetNull)
  sales        Sale[]
  cashRegisters CashRegister[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String   @id @default(cuid())
  kioskId     String
  name        String
  phone       String
  points      Int      @default(0)
  totalSpent  Float    @default(0)
  kiosk       Kiosk    @relation(fields: [kioskId], references: [id], onDelete: Cascade)
  sales       Sale[]   @relation("ClientSales")
  redemptions PointRedemption[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([kioskId, phone])
  @@index([kioskId])
}

model LoyaltyRule {
  id               Int     @id @default(1)
  amountPerPoint   Float
  pointsForDiscount Int
  discountAmount   Float
  active           Boolean @default(true)
}

model PointRedemption {
  id        String   @id @default(cuid())
  clientId  String
  pointsUsed Int
  discount  Float
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(cuid())
  kioskId       String
  saleId        String?
  invoiceType   String
  invoiceNumber String
  total         Float
  status        String
  createdAt     DateTime @default(now())
  kiosk         Kiosk    @relation(fields: [kioskId], references: [id], onDelete: Cascade)

  @@index([kioskId])
  @@index([kioskId, createdAt])
  @@index([saleId])
  @@index([createdAt])
}

model Purchase {
  id         String   @id @default(cuid())
  supplierId String
  status     String   @default("PENDING")
  paymentMethod String @default("CASH")
  deliveryDate DateTime?
  notes      String?
  totalAmount Float   @default(0)
  receivedAt DateTime?
  createdAt  DateTime @default(now())
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  items      PurchaseItem[]

  @@index([supplierId, createdAt])
  @@index([status])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitCost   Float
  lineTotal  Float
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
}

model CashRegister {
  id             String   @id @default(cuid())
  userId         String
  status         String   @default("OPEN")
  openingAmount  Float
  expectedAmount Float?
  actualAmount   Float?
  difference     Float?
  notes          String?
  openedAt       DateTime @default(now())
  closedAt       DateTime?
  user           User     @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([openedAt])
  @@index([userId])
}
